[
    {
        "name": "AumStaff",
        "trigger": null,
        "level_nid": null,
        "condition": "True",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "# Create a choice menu listing the dead units",
            "choice;AmaterasuChoice;Who to revive?;[unit.nid for unit in game.get_all_units_in_party('Krista') if game.check_dead(unit.nid) == True];;vertical;center;EntryType=type_unit;scroll_bar;expression",
            "resurrect;{e:v('AmaterasuChoice')}",
            "# Raise chosen unit's level and class to the average of the currently deployed party",
            "lvar;LevelCalc;0",
            "for;PartyLevel;[unit for unit in game.get_player_units_and_travelers() if unit.team == 'player']",
            "  linc;LevelCalc;u('{PartyLevel}').get_internal_level()",
            "endf",
            "lvar;LevelCalc;{e:v('LevelCalc') // len([unit for unit in game.get_player_units_and_travelers() if unit.team == 'player'])}",
            "if;u('{v:AmaterasuChoice}').get_internal_level() < v('LevelCalc')",
            "  if;v('LevelCalc') > 20",
            "    if;u('{v:AmaterasuChoice}').get_internal_level() < 15",
            "      autolevel_to;{e:v('AmaterasuChoice')};15",
            "    end",
            "    promote;{e:v('AmaterasuChoice')};silent",
            "    if;v('LevelCalc') > 20 and v('LevelCalc') < 40",
            "      lvar;LevelCalc;{e:v('LevelCalc') % 20}",
            "    else",
            "      autolevel_to;{e:v('AmaterasuChoice')};15",
            "      promote;{e:v('AmaterasuChoice')};silent",
            "      lvar;LevelCalc;{e:v('LevelCalc') % 40}",
            "    end",
            "  end",
            "  autolevel_to;{e:v('AmaterasuChoice')};{v:LevelCalc}",
            "end",
            "# Add revived unit to the map",
            "set_current_hp;{e:v('AmaterasuChoice')};999",
            "add;{e:v('AmaterasuChoice')};{target_pos};warp;closest;fade"
        ],
        "nid": "Global AumStaff"
    }
]