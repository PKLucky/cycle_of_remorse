[
    {
        "name": "Turn1",
        "trigger": "turn_change",
        "level_nid": "15",
        "condition": "game.turncount == 1",
        "commands": [],
        "only_once": true,
        "priority": 20,
        "_source": [
            "if;u('Sam').position != None",
            "  lvar;AltenaHint;True",
            "end",
            "lvar;deployedUnits;[]",
            "for;PartyMembers;[unit.nid for unit in game.get_player_units()]",
            "  give_skill;{PartyMembers};ArenaDurability;no_banner",
            "  mlvar;deployedUnits;it.append('{PartyMembers}')",
            "endf",
            "if;len(game.get_open_formation_spots()) > 0",
            "  lvar;ArenaEnemyKlassList;[klass.nid for klass in DB.classes if 'ArenaIgnore' not in klass.tags and klass.tier < 3]",
            "  for;spawnGreen;game.get_open_formation_spots()",
            "    lvar;KlassRNG;game.get_random(0, len(v('ArenaEnemyKlassList')) - 1)",
            "    lvar;ArenaEnemyKlass;game.level_vars['ArenaEnemyKlassList'][game.level_vars['KlassRNG']]",
            "    make_generic;;{v:ArenaEnemyKlass};1;other;Ch15;Enemy",
            "    if;DB.classes.get(u('{created_unit}').klass).tier == 2",
            "      autolevel_to;{created_unit};{e:game.get_random(1,5)};random",
            "    else",
            "      autolevel_to;{created_unit};{e:game.get_random(11,19)};random",
            "    end",
            "    trigger_script;Global RandomGender;{created_unit}",
            "    for;LoadItem;[w for w in DB.classes.get(u('{created_unit}').klass).wexp_gain if DB.classes.get(u('{created_unit}').klass).wexp_gain[w].usable == True]",
            "      set_wexp;{created_unit};{LoadItem};131;no_banner",
            "      give_item;{created_unit};{e:game.level_vars['WeaponDict']['{LoadItem}']};no_banner",
            "    endf",
            "    lvar;CurrentCarry;len(u('{created_unit}').items) - 1",
            "    for;RemoveInventory;range(0,{v:CurrentCarry})",
            "      lvar;ItemRemove;game.get_random(0,len(u('{created_unit}').items) - 1)",
            "      remove_item;{created_unit};{e:u('{created_unit}').items[{v:ItemRemove}]};no_banner",
            "    endf",
            "    add;{created_unit};{spawnGreen};immediate;stack",
            "    give_skill;{created_unit};ArenaDurability;no_banner",
            "  endf",
            "end"
        ],
        "nid": "15 Turn1"
    }
]