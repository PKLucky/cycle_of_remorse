[
    {
        "name": "Arena",
        "trigger": "Arena",
        "level_nid": "7a",
        "condition": "not u('Joshua') or u('Joshua').team != 'player'",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "# Get the NIDs and positions of all units on the map and store them into variables. This will be used to put the units back after the arena battle.",
            "lvar;SavedUnitNids;[unit.nid for unit in game.get_all_units()]",
            "lvar;SavedUnitPositions;[unit.position for unit in game.get_all_units()]",
            "# Changes terrain to Arena terrain. Add an Arena layer to the tilemap in the Tilemap editor to chapters with an arena.",
            "show_layer;arena;immediate",
            "t;Close",
            "remove_all_units",
            "add;{unit};{position};immediate;stack",
            "give_skill;{unit};ArenaDurability;no_banner",
            "# Load Joshua in",
            "load_unit;Joshua;enemy",
            "if;game.current_mode.growths == 'Lucky'",
            "  autolevel_to;Joshua;9;lucky",
            "else",
            "  autolevel_to;Joshua;9;fixed",
            "end",
            "set_wexp;Joshua;Sword;31;no_banner",
            "give_item;Joshua;Iron Sword;no_banner",
            "equip_item;Joshua;Iron Sword",
            "give_item;Joshua;Red Gem;no_banner",
            "give_skill;Joshua;ArenaDurability;no_banner",
            "# Calculate level range for enemy and pick level at random",
            "lvar;low_level;max(1,unit.level - 4)",
            "lvar;high_level;min(20, unit.level + 4)",
            "lvar;EnemyLevel;u('Joshua').level",
            "# Calculate arena wager based on enemy level",
            "lvar;ArenaPercent;(v('EnemyLevel') - v('low_level')) / float(v('high_level') - v('low_level'))",
            "lvar;ArenaWager;int(min(550 + v('ArenaPercent') * (1100 - 550), game.get_money()))",
            "if;{v:ArenaWager} < 0",
            "  lvar;ArenaWager;{e:v('ArenaWager') * -1}",
            "end",
            "# Spawn enemy",
            "add;Joshua;{unit};immediate;closest",
            "b;ArenaEntrance",
            "draw_overlay_sprite;ArenaPortrait;arena_portrait;4,4;1",
            "table;GoldDisplay;game.get_money();;;60;right;funds_display;;center;expression",
            "# Fade to arena background",
            "t;open",
            "m;Arena Entrance",
            "if;game.get_money() == 0",
            "  s;;What! You don't have any money! Get out of here!;top_right;160;noir",
            "elif;unit.get_weapon()",
            "  s;;Welcome to the arena!;top_right;160;noir",
            "  # Get name of class to display on table",
            "  textbox;OpponentStats;Opponent: Mercenary - Iron Sword{br}Level: 9;bottom;200;2",
            "  choice;ArenaChoice;Would you like to wager {var:ArenaWager} gold?;Yes,No;backable",
            "  if;v('ArenaChoice') == 'Yes'",
            "    sound;GoldExchange",
            "    give_money;{e:-v('ArenaWager')};no_banner",
            "    change_music;player_battle;Arena Battle",
            "    s;;Good luck. Don't get yourself killed.|Fight 'til defeat or press B to yield.;top_right;160;noir",
            "    rmtable;OpponentStats",
            "    u;Joshua;Left",
            "    if;v('JoshuaFight') == True",
            "      s;Joshua;Up for a rematch, huh? Alright, show me what you got!",
            "    else",
            "      s;Joshua;Hey, you're my opponent this round?|Let's make this interesting, then!|See, I hit pretty hard, so most people go down easy if they're up against me.|If you survive for one round, I'll say that you won. Sound like a plan?|{c:e;Joshua;Smile}Great! Let's go!",
            "      lvar;JoshuaFight;True",
            "    end",
            "    r;Joshua",
            "    t;close",
            "    b;combat_arena",
            "    interact;{unit};Joshua;--;;1;arena;force_animation",
            "    end_skip",
            "    if;game.check_dead('Joshua') == True or game.check_dead('{unit}') == False",
            "      resurrect;Joshua",
            "      change_team;Joshua;player",
            "      b;ArenaEntrance",
            "      t;open",
            "      m;_Arena Victory",
            "      s;;So you won, eh? Here's your prize. {e:2*v('ArenaWager')} gold.;top_right;160;noir",
            "      sound;GoldExchange",
            "      give_money;{e:2*v('ArenaWager')}",
            "      mf;100",
            "      m;Together We Ride",
            "      u;Joshua;Left;;Smile",
            "      s;Joshua;Not bad. I like you!|{c:e;Joshua;NoSmile}What's that? You need people to join your army?|{c:e;Joshua;Smile}If there's more people like you in it, then count me in!",
            "      remove_item;Joshua;Iron Sword;no_banner",
            "      music_clear",
            "    end",
            "    change_music;player_battle;Dokapon Normal Battle",
            "    has_attacked;{unit}",
            "  else",
            "    s;;What are you wasting my time for?;top_right;160;noir",
            "    rmtable;OpponentStats",
            "  end",
            "else",
            "  s;;What! You don't have a weapon! Get out of here!;top_right;160;noir",
            "end",
            "t;close",
            "# Clean up after a round at the arena.",
            "b",
            "for;ReturnUnits;range(0,len(v('SavedUnitNids')))",
            "  add;{e:game.level_vars['SavedUnitNids'][{ReturnUnits}]};{e:game.level_vars['SavedUnitPositions'][{ReturnUnits}]};immediate;stack",
            "endf",
            "if;u('Joshua').team != 'player'",
            "  remove;Joshua;immediate",
            "  set_current_hp;Joshua;99",
            "else",
            "  add;Joshua;{unit};immediate;closest",
            "end",
            "hide_layer;arena;immediate",
            "remove;{created_unit};immediate",
            "rmtable;GoldDisplay",
            "remove_overlay_sprite;ArenaPortrait",
            "remove_skill;{unit};ArenaDurability;no_banner",
            "remove_skill;Joshua;ArenaDurability;no_banner",
            "t;open",
            "mf"
        ],
        "nid": "7a Arena"
    }
]