[
    {
        "name": "Arena",
        "trigger": "Arena",
        "level_nid": null,
        "condition": "game.level.nid != '7a' or u('Joshua').team == 'player'",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "# Get the NIDs and positions of all units on the map and store them into variables. This will be used to put the units back after the arena battle.",
            "lvar;SavedUnitNids;[unit.nid for unit in game.get_all_units()]",
            "lvar;SavedUnitPositions;[unit.position for unit in game.get_all_units()]",
            "# Changes terrain to Arena terrain. Add an Arena layer to the tilemap in the Tilemap editor to chapters with an arena.",
            "show_layer;arena;immediate",
            "t;Close",
            "remove_all_units",
            "add;{unit};{position};immediate;stack",
            "# Adds a dummy unit so that chapters with a Rout objective don't trigger their win condition after winning an arena battle",
            "make_generic;DUMMY;Citizen;1;enemy;None;Enemy",
            "add;DUMMY;{position};immediate;closest",
            "# Find tier of class of player unit to determine enemy's tier",
            "lvar;EnemyTier;DB.classes.get(unit.klass).tier",
            "# Randomly choose the enemy's class from the pool. Add the tag ArenaIgnore to any classes that won't show up in the arena.",
            "lvar;ArenaEnemyKlassList;[klass.nid for klass in DB.classes if 'ArenaIgnore' not in klass.tags and klass.tier == v('EnemyTier')]",
            "lvar;KlassRNG;game.get_random(0, len(v('ArenaEnemyKlassList')) - 1)",
            "lvar;ArenaEnemyKlass;game.level_vars['ArenaEnemyKlassList'][game.level_vars['KlassRNG']]",
            "# Calculate level range for enemy and pick level at random",
            "lvar;low_level;max(1,unit.level - 4)",
            "lvar;high_level;min(20, unit.level + 4)",
            "lvar;EnemyLevel;game.get_random(v('low_level'),v('high_level'))",
            "# Calculate arena wager based on enemy level",
            "lvar;ArenaPercent;(v('EnemyLevel') - v('low_level')) / float(v('high_level') - v('low_level'))",
            "lvar;ArenaWager;int(min(550 + v('ArenaPercent') * (1100 - 550), game.get_money()))",
            "# Spawn enemy",
            "make_generic;;{v:ArenaEnemyKlass};{v:EnemyLevel};enemy;None;Enemy",
            "add;{created_unit};{unit};immediate;closest",
            "# Equip enemy with weapon. Determines what weapons are available to equip based on WEXP defined in the Class Editor.",
            "lvar;WeaponDict;{'Sword':'Iron Sword','Lance':'Iron Lance','Axe':'Iron Axe','Bow':'Iron Bow','Anima':'Fire','Light':'Lightning','Dark':'Flux'}",
            "for;LoadItem;[w for w in DB.classes.get(u('{created_unit}').klass).wexp_gain if DB.classes.get(u('{created_unit}').klass).wexp_gain[w].usable == True]",
            "  set_wexp;{created_unit};{LoadItem};1;no_banner",
            "  give_item;{created_unit};{e:game.level_vars['WeaponDict']['{LoadItem}']};no_banner",
            "endf",
            "# Randomly choose which weapon to equip.",
            "lvar;InventorySlot;game.get_random(0,len(u('{created_unit}').items) - 1)",
            "equip_item;{created_unit};{e:u('{created_unit}').items[{v:InventorySlot}]}",
            "if;game.get_random(1,4) == 1 and not has_item('ArenaPass',party='Krista') and not has_item('ArenaPass',team='enemy')",
            "  give_item;{created_unit};ArenaPass;droppable;no_banner",
            "end",
            "#Moves the unit away from the player unit so they can retaliate if equipped with a bow.",
            "if;u('{created_unit}').get_weapon().weapon_type.value == 'Bow'",
            "  move;{created_unit};{e:u('{unit}').position[0] - 1},{e:u('{unit}').position[1] - 1};immediate;stack",
            "end",
            "b;ArenaEntrance",
            "draw_overlay_sprite;ArenaPortrait;arena_portrait;4,4;1",
            "table;GoldDisplay;game.get_money();;;60;right;funds_display;;center;expression",
            "# Fade to arena background",
            "t;open",
            "m;Arena Entrance",
            "if;game.get_money() == 0",
            "  s;;What! You don't have any money! Get out of here!;top_right;160;noir",
            "elif;unit.get_weapon()",
            "  s;;Welcome to the arena!;top_right;160;noir",
            "  # Get name of class to display on table",
            "  lvar;ArenaEnemyKlass;DB.classes.get(u('{created_unit}').klass).name",
            "  lvar;ArenaItem;u('{created_unit}').get_weapon().name",
            "  textbox;OpponentStats;Opponent: {v:ArenaEnemyKlass} - {v:ArenaItem}{br}Level: {e:u('{created_unit}').level};bottom;200;2",
            "  choice;ArenaChoice;Would you like to wager {v:ArenaWager} gold?;Yes,No;backable",
            "  if;v('ArenaChoice') == 'Yes'",
            "    sound;GoldExchange",
            "    give_money;{e:-v('ArenaWager')};no_banner",
            "    change_music;player_battle;Arena Battle",
            "    s;;Good luck. Don't get yourself killed.|Fight 'til defeat or press B to yield.;top_right;160;noir",
            "    rmtable;OpponentStats",
            "    t;close",
            "    b;combat_arena",
            "    interact;{unit};{created_unit};;;20;arena;force_animation",
            "    end_skip",
            "    if;game.check_dead('{created_unit}')",
            "      b;ArenaEntrance",
            "      t;open",
            "      m;_Arena Victory",
            "      s;;So you won, eh? Here's your prize. {e:2*v('ArenaWager')} gold.;top_right;160;noir",
            "      sound;GoldExchange",
            "      give_money;{e:2*v('ArenaWager')}",
            "      mf;100",
            "    end",
            "    if;v('ChapterFlag') >= 11 and v('ChapterFlag') < 21",
            "      change_music;player_battle;Far Dawn",
            "    else",
            "      change_music;player_battle;Dokapon Normal Battle",
            "    end",
            "    if;has_item('ArenaPass',u('{unit}').nid) == True",
            "      reset;{unit}",
            "    end",
            "  else",
            "    s;;What are you wasting my time for?;top_right;160;noir",
            "    rmtable;OpponentStats",
            "  end",
            "else",
            "  s;;What! You don't have a weapon! Get out of here!;top_right;160;noir",
            "end",
            "t;close",
            "# Clean up after a round at the arena.",
            "b",
            "hide_layer;arena;immediate",
            "remove;{created_unit};immediate",
            "remove;DUMMY;immediate",
            "rmtable;GoldDisplay",
            "remove_overlay_sprite;ArenaPortrait",
            "remove_skill;{unit};ArenaDurability;no_banner",
            "for;ReturnUnits;range(0,len(v('SavedUnitNids')))",
            "  add;{e:game.level_vars['SavedUnitNids'][{ReturnUnits}]};{e:game.level_vars['SavedUnitPositions'][{ReturnUnits}]};immediate;stack",
            "endf",
            "t;open",
            "mf"
        ],
        "nid": "Global Arena"
    }
]