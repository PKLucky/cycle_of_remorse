[
    {
        "name": "Seize",
        "trigger": "Seize",
        "level_nid": "7x",
        "condition": "True",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "if;unit.team == 'player'",
            "  linc;fortsSeizedTotal",
            "  if;region.nid == 'Fort'",
            "    show_layer;FortNW",
            "    mlvar;fortsSeized;it.update({'Fort':True})",
            "  elif;region.nid == 'Fort1'",
            "    mlvar;fortsSeized;it.update({'Fort1':True})",
            "    show_layer;FortNE",
            "  elif;region.nid == 'Fort2'",
            "    mlvar;fortsSeized;it.update({'Fort2':True})",
            "    show_layer;FortSW",
            "  elif;region.nid == 'Fort3'",
            "    mlvar;fortsSeized;it.update({'Fort3':True})",
            "    show_layer;FortSE",
            "  elif;region.nid == 'Fort4'",
            "    mlvar;fortsSeized;it.update({'Fort4':True})",
            "  show_layer;FortLake",
            "  end",
            "  if;v('fortsSeizedTotal') == 1",
            "    u;Anna;Left",
            "    s;Anna;One fort seized! Keep it up, everyone!",
            "    r;Anna",
            "    if;v('fortDialogue') != True",
            "      center_cursor;Daphne",
            "      flicker_cursor;Daphne",
            "      u;Daphne;Right",
            "      s;Daphne;They took one of the forts!|Soldiers, reclaim it before they seize any more!",
            "      r;Daphne",
            "      center_cursor;{unit}",
            "      lvar;fortDialogue;True",
            "    end",
            "  elif;v('fortsSeizedTotal') == 2",
            "    u;Jake;Left",
            "    s;Jake;Got another one! Just a few more to go!",
            "    r;Jake",
            "  elif;v('fortsSeizedTotal') == 3",
            "    u;Anna;Left",
            "    s;Anna;Two forts left, everyone!",
            "    r;Anna",
            "  elif;v('fortsSeizedTotal') == 4",
            "    u;Jake;Left",
            "    s;Jake;Just one more to go!",
            "    r;Jake",
            "  end",
            "  if;has_skill('{unit}', 'ThiefsExpertise') and unit.team == 'player'",
            "    give_exp;{unit};42",
            "  else",
            "    give_exp;{unit};21",
            "  end",
            "  if;v('fortsSeizedTotal') == 5",
            "    music_clear",
            "    victory_screen",
            "    win_game",
            "  else",
            "    has_traded;{unit}",
            "  end",
            "else",
            "  linc;fortsSeizedTotal;-1",
            "  if;region.nid == 'Fort_1'",
            "    hide_layer;FortNW",
            "    mlvar;fortsSeized;it.update({'Fort':False})",
            "  elif;region.nid == 'Fort1_1'",
            "    mlvar;fortsSeized;it.update({'Fort1':False})",
            "    hide_layer;FortNE",
            "  elif;region.nid == 'Fort2_1'",
            "    mlvar;fortsSeized;it.update({'Fort2':False})",
            "    hide_layer;FortSW",
            "  elif;region.nid == 'Fort3_1'",
            "    mlvar;fortsSeized;it.update({'Fort3':False})",
            "    hide_layer;FortSE",
            "  elif;region.nid == 'Fort4_1'",
            "    mlvar;fortsSeized;it.update({'Fort4':False})",
            "    hide_layer;FortLake",
            "  end",
            "  sound;ItemBreak",
            "  alert;Fort reclaimed by the enemy!",
            "end"
        ],
        "nid": "7x Seize"
    }
]