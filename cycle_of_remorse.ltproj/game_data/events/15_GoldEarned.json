[
    {
        "name": "GoldEarned",
        "trigger": "unit_death",
        "level_nid": "15",
        "condition": "unit.nid != 'wall' and unit2.team == 'player'",
        "commands": [],
        "only_once": false,
        "priority": 21,
        "_source": [
            "# Find tier of class of player unit",
            "lvar;playerClassTier;DB.classes.get(unit2.klass).tier",
            "lvar;enemyClassTier;DB.classes.get(unit.klass).tier",
            "# Determine gold earned #",
            "if;v('playerClassTier') < v('enemyClassTier')",
            "  give_money;1100",
            "elif;unit2.level - unit.level > 4 or v('playerClassTier') > v('enemyClassTier') or unit2.level == unit.level",
            "  give_money;550",
            "else",
            "  lvar;ArenaPercent;(unit.level - (unit2.level - 4)) / unit2.level",
            "  lvar;ArenaWager;int(550 + v('ArenaPercent') * (1100 - 550))",
            "  give_money;{v:ArenaWager}",
            "end"
        ],
        "nid": "15 GoldEarned"
    }
]